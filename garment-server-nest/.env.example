# Phase 1 环境变量样例(复制为 .env 后填实际值)

# NestJS 监听端口(3002,与 Express 3001 区分)
PORT=3002

# SQLite 数据库路径
# 默认 ../garment-server/data.sqlite(共享)
# 测试时改 :memory:
DB_PATH=

# 开启 DB 查询日志(默认 false)
DB_LOG=false

# Redis 连接 URL
# 开发:本机 redis
# 生产:docker compose 内 redis://redis:6379
REDIS_URL=redis://localhost:6379

# Session 加密 secret
# ⚠️ 必须与 garment-server/server.js 的 SESSION_SECRET 一致(否则 cookie 跨进程不识别)
# Express 默认值:'garment-session-dev-secret'(Phase 1 用此对齐)
SESSION_SECRET=garment-session-dev-secret

# 跨进程 cookie 共享(必须与 Express 一致)
COOKIE_NAME=connect.sid

# CORS 白名单(逗号分隔);迁移期留空=全开
CORS_ORIGINS=