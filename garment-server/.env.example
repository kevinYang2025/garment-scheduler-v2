# garment-server 生产环境变量模板
# 真实文件: /opt/garment/env/garment.env (服务器上, chmod 600, 不在 git 里)
# 生成密钥: openssl rand -hex 32
# ⚠️ 生产环境 NODE_ENV=production 时,AUTH_ENABLED 必须为 true 且 API_TOKEN 不能为默认值,否则 server.js:47-58 会强制 exit(1)

# ====== 必填 ======
NODE_ENV=production
AUTH_ENABLED=true
API_TOKEN=__REPLACE_WITH_openssl_rand_hex_32__
SESSION_SECRET=__REPLACE_WITH_openssl_rand_hex_32__
# CORS_ORIGINS 不能是 *,因为 axios 使用 withCredentials: true (api/index.js:7)
# 必须填写前端实际访问的 https origin,逗号分隔
CORS_ORIGINS=https://garment.example.com

# ====== 监听 (默认 3001, 仅监听 loopback, Nginx 是公网入口) ======
PORT=3001
HOST=127.0.0.1

# ====== 可选 ======
# DB_PATH=/opt/garment/data/data.sqlite
# LOG_LEVEL=info
# NODE_EXTRA_CA_CERTS=/opt/garment/certs/ca-bundle.crt  # [2026-06-20 fix#后端-P3-9] 内部 CA 或代理时的额外证书
# SESSION_STORE_PATH=/opt/garment/data/sessions.db        # SQLite session store 路径(默认 cwd/sessions.db)
